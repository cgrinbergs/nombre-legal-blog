    <!-- Process Timeline Section -->
    <section id="proceso" class="py-16 lg:py-24 bg-cream-100">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <p class="text-dark-muted text-sm font-medium mb-2">Ley 17.344</p>
                <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">Etapas del Proceso</h2>
            </div>

            <!-- Interactive Timeline -->
            <div class="max-w-2xl mx-auto space-y-3">
                <!-- Step 1 -->
                <div class="timeline-item bg-white rounded-xl border border-cream-200 overflow-hidden">
                    <button class="timeline-btn w-full px-5 py-4 flex items-center justify-between hover:bg-cream-50 transition-colors" onclick="toggleTimeline(this)">
                        <div class="flex items-center">
                            <span class="w-8 h-8 bg-dark text-white rounded-lg flex items-center justify-center text-sm font-bold mr-4">1</span>
                            <span class="font-medium">Consulta inicial</span>
                        </div>
                        <svg class="timeline-icon w-5 h-5 text-dark-muted transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="timeline-content hidden px-5 pb-4 pt-0">
                        <div class="pl-12 border-l-2 border-cream-200 ml-4">
                            <p class="text-dark-light text-sm mb-3">Evaluamos tu caso y determinamos la <strong>causal legal</strong> aplicable según la Ley 17.344: nombre ridículo o que causa menoscabo, uso de otro nombre por más de 5 años, traducción de nombre extranjero, entre otras.</p>
                            <span class="inline-block px-2 py-1 bg-green-100 text-green-700 text-xs rounded">Sin costo</span>
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="timeline-item bg-white rounded-xl border border-cream-200 overflow-hidden">
                    <button class="timeline-btn w-full px-5 py-4 flex items-center justify-between hover:bg-cream-50 transition-colors" onclick="toggleTimeline(this)">
                        <div class="flex items-center">
                            <span class="w-8 h-8 bg-dark text-white rounded-lg flex items-center justify-center text-sm font-bold mr-4">2</span>
                            <span class="font-medium">Preparación de documentos</span>
                        </div>
                        <svg class="timeline-icon w-5 h-5 text-dark-muted transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="timeline-content hidden px-5 pb-4 pt-0">
                        <div class="pl-12 border-l-2 border-cream-200 ml-4">
                            <p class="text-dark-light text-sm mb-3">Recopilamos certificado de nacimiento, certificado de antecedentes, y redactamos la demanda judicial fundamentando la causal invocada.</p>
                            <span class="inline-block px-2 py-1 bg-cream-100 text-dark-muted text-xs rounded">1-2 semanas</span>
                        </div>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="timeline-item bg-white rounded-xl border border-cream-200 overflow-hidden">
                    <button class="timeline-btn w-full px-5 py-4 flex items-center justify-between hover:bg-cream-50 transition-colors" onclick="toggleTimeline(this)">
                        <div class="flex items-center">
                            <span class="w-8 h-8 bg-dark text-white rounded-lg flex items-center justify-center text-sm font-bold mr-4">3</span>
                            <span class="font-medium">Presentación ante tribunal</span>
                        </div>
                        <svg class="timeline-icon w-5 h-5 text-dark-muted transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="timeline-content hidden px-5 pb-4 pt-0">
                        <div class="pl-12 border-l-2 border-cream-200 ml-4">
                            <p class="text-dark-light text-sm mb-3">Ingresamos la demanda al <strong>Juzgado de Letras Civil</strong> de tu domicilio. El tribunal revisa admisibilidad y asigna un rol a la causa.</p>
                            <span class="inline-block px-2 py-1 bg-cream-100 text-dark-muted text-xs rounded">Variable</span>
                        </div>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="timeline-item bg-white rounded-xl border border-cream-200 overflow-hidden">
                    <button class="timeline-btn w-full px-5 py-4 flex items-center justify-between hover:bg-cream-50 transition-colors" onclick="toggleTimeline(this)">
                        <div class="flex items-center">
                            <span class="w-8 h-8 bg-dark text-white rounded-lg flex items-center justify-center text-sm font-bold mr-4">4</span>
                            <span class="font-medium">Publicación en Diario Oficial</span>
                        </div>
                        <svg class="timeline-icon w-5 h-5 text-dark-muted transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="timeline-content hidden px-5 pb-4 pt-0">
                        <div class="pl-12 border-l-2 border-cream-200 ml-4">
                            <p class="text-dark-light text-sm mb-3">Se publica extracto de la solicitud en el Diario Oficial (días 1 o 15 de cada mes). Inicia período de <strong>30 días hábiles</strong> para oposiciones de terceros.</p>
                            <span class="inline-block px-2 py-1 bg-amber-100 text-amber-700 text-xs rounded">30 días hábiles (legal)</span>
                        </div>
                    </div>
                </div>

                <!-- Step 5 -->
                <div class="timeline-item bg-white rounded-xl border border-cream-200 overflow-hidden">
                    <button class="timeline-btn w-full px-5 py-4 flex items-center justify-between hover:bg-cream-50 transition-colors" onclick="toggleTimeline(this)">
                        <div class="flex items-center">
                            <span class="w-8 h-8 bg-dark text-white rounded-lg flex items-center justify-center text-sm font-bold mr-4">5</span>
                            <span class="font-medium">Audiencia con testigos</span>
                        </div>
                        <svg class="timeline-icon w-5 h-5 text-dark-muted transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
