    <!-- JavaScript -->
    <script is:inline>
        // Mobile menu toggle
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Close mobile menu when clicking a link
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });

        // Google Ads GCLID capture
        function getGclid() {
            const storedGclid = localStorage.getItem('gclid');
            if (storedGclid) return storedGclid;

            const urlParams = new URLSearchParams(window.location.search);
            const gclid = urlParams.get('gclid');
            if (gclid) {
                localStorage.setItem('gclid', gclid);
                return gclid;
            }
            return null;
        }

        (function() {
            const gclid = getGclid();
            if (gclid && window.posthog) {
                posthog.register({ gclid: gclid });
            }
        })();

        // Telegram Bot
        const TELEGRAM_BOT_TOKEN = '8200846082:AAFEXMBVPDUIxIKBcbivyUcK0GFftew4hDs';
        const TELEGRAM_CHAT_ID = '1686674702';

        // Form submission
        async function enviarWhatsApp(event) {
            event.preventDefault();

            const form = event.target;
            const formData = new FormData(form);

            const nombre = formData.get('nombre') || '';
            const telefono = formData.get('telefono') || '';
            const email = formData.get('email') || '';

            // PostHog tracking
            if (window.posthog) {
                if (email) {
                    posthog.identify(email, {
                        name: nombre,
                        phone: telefono,
                        email: email
                    });
                }
                posthog.capture('lead_submitted', {
                    nombre: nombre,
                    tiene_telefono: !!telefono,
                    tiene_email: !!email,
                    formulario: form.id,
                    gclid: getGclid()
                });
            }

            // GTM
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
                'event': 'lead_submitted',
                'lead_name': nombre,
                'lead_email': email,
                'lead_form': form.id
            });

            // Telegram notification
            if (TELEGRAM_BOT_TOKEN !== 'TU_BOT_TOKEN') {
                const mensaje = `🔔 *Nuevo Lead*\n\n👤 *Nombre:* ${nombre}\n📞 *Teléfono:* ${telefono}\n📧 *Email:* ${email}`;
                fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        chat_id: TELEGRAM_CHAT_ID,
                        text: mensaje,
                        parse_mode: 'Markdown'
                    })
                }).catch(err => console.log('Error enviando a Telegram:', err));
            }

            // Email via Cloudflare Worker
            fetch('https://resend-proxy.csgrinbergs.workers.dev', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    from: 'Nombre Legal <notificaciones@nombrelegal.cl>',
                    to: ['csgrinbergs@gmail.com', 'alagnomarin@gmail.com'],
                    subject: `Nuevo Lead: ${nombre}`,
                    html: `
                        <h2>Nuevo Lead desde nombrelegal.cl</h2>
                        <p><strong>Nombre:</strong> ${nombre}</p>
                        <p><strong>Teléfono:</strong> ${telefono || 'No proporcionado'}</p>
                        <p><strong>Email:</strong> ${email || 'No proporcionado'}</p>
                        <p><a href="https://wa.me/56${telefono?.replace(/\s/g, '').replace('+56', '')}">Contactar por WhatsApp</a></p>
                    `
                })
            }).catch(err => console.log('Error enviando email:', err));

            // Show confirmation
            form.innerHTML = `
                <div class="text-center py-8">
                    <svg class="w-16 h-16 mx-auto text-green-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <h3 class="text-xl font-semibold mb-2">¡Mensaje enviado!</h3>
                    <p class="text-dark-muted">Te contactaremos pronto por WhatsApp.</p>
                </div>
            `;

            return false;
        }

        // Timeline Accordion
        function toggleTimeline(button) {
            const item = button.closest('.timeline-item');
            const content = item.querySelector('.timeline-content');
            const icon = button.querySelector('.timeline-icon');
            content.classList.toggle('hidden');
            icon.classList.toggle('rotate-180');
        }

        // FAQ Accordion
        function toggleFaq(button) {
            const faqItem = button.closest('.faq-item');
            const content = faqItem.querySelector('.faq-content');
            const icon = faqItem.querySelector('.faq-icon');

            document.querySelectorAll('.faq-item').forEach(item => {
                if (item !== faqItem) {
                    item.querySelector('.faq-content').classList.add('hidden');
                    item.querySelector('.faq-icon').classList.remove('rotate-180');
                }
            });

            content.classList.toggle('hidden');
            icon.classList.toggle('rotate-180');
        }
    </script>
