---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe."
  noindex={true}
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <p class="text-6xl font-bold text-[#E5E0D8] mb-4">404</p>
    <h1 class="text-2xl font-semibold text-[#1A1A1A] mb-3">Página no encontrada</h1>
    <p class="text-[#4A4A4A] mb-8 max-w-sm">
      El artículo o página que buscas no existe o fue movido.
    </p>
    <div class="flex gap-4">
      <a href="/blog"
         class="px-5 py-2.5 bg-[#1A1A1A] text-white rounded-full text-sm font-medium hover:bg-[#4A4A4A] transition-colors">
        Ver el blog
      </a>
      <a href="/"
         class="px-5 py-2.5 border border-[#E5E0D8] text-[#1A1A1A] rounded-full text-sm font-medium hover:bg-[#F5F0E8] transition-colors">
        Ir al inicio
      </a>
    </div>
  </div>
</BaseLayout>
