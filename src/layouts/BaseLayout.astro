      posthog.init('phc_MNqyAHXrvsMk23JWlNycH3jgYexvlhpCLz89qOvHSG4', {
        api_host: 'https://us.i.posthog.com',
        person_profiles: 'identified_only',
        capture_pageview: true,
        capture_pageleave: true,
        autocapture: true,
      });
    </script>

    <slot name="head" />
  </head>
  <body class="bg-[#FFFBF5] font-sans text-[#1A1A1A] antialiased" style="font-family: 'Inter', system-ui, sans-serif;">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 bg-[#FFFBF5]/80 backdrop-blur-md z-50 border-b border-[#E5E0D8]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 font-bold text-[#1A1A1A]">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 80 80">
              <circle cx="40" cy="8" r="5" fill="#1A1A1A"/>
              <rect x="4" y="12" width="72" height="5" rx="2" fill="#1A1A1A"/>
              <rect x="37" y="17" width="6" height="35" fill="#1A1A1A"/>
              <rect x="26" y="52" width="28" height="5" rx="2" fill="#1A1A1A"/>
              <line x1="10" y1="17" x2="10" y2="36" stroke="#1A1A1A" stroke-width="3" stroke-linecap="round"/>
              <line x1="70" y1="17" x2="70" y2="36" stroke="#1A1A1A" stroke-width="3" stroke-linecap="round"/>
              <ellipse cx="10" cy="40" rx="13" ry="4" fill="#D4A84B"/>
              <path d="M-3 40 Q10 52 23 40" fill="#B8872B"/>
              <ellipse cx="70" cy="40" rx="13" ry="4" fill="#D4A84B"/>
              <path d="M57 40 Q70 52 83 40" fill="#B8872B"/>
            </svg>
            <span>Nombre <span class="text-[#B8872B]">Legal</span></span>
          </a>
          <nav class="hidden sm:flex items-center gap-6 text-sm text-[#4A4A4A]">
            <a href="/blog" class="hover:text-[#1A1A1A] transition-colors">Blog</a>
          </nav>
          <a href="/#contacto"
             class="text-sm font-medium px-4 py-2 bg-[#1A1A1A] text-white rounded-full hover:bg-[#4A4A4A] transition-colors">
            Consulta Gratis
          </a>
        </div>
      </div>
    </header>

    <main class="pt-14">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-24 py-12 border-t border-[#E5E0D8]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-[#8A8A8A]">
        <p>
          <a href="/" class="hover:text-[#1A1A1A] transition-colors font-medium">Nombre Legal</a>
          — Especialistas en cambio de nombre en Chile
        </p>
        <p class="mt-2">
          El contenido de este blog es informativo y no constituye asesoría legal profesional.
        </p>
      </div>
    </footer>
  </body>
</html>
